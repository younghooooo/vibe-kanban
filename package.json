{
  "name": "vibe-kanban",
  "version": "0.3.0",
  "description": "AI-powered personal kanban board with Claude",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "author": "you",
  "license": "MIT",
  "dependencies": {
    "@tiptap/core": "^2.0.0",
    "@tiptap/extension-code-block-lowlight": "^2.0.0",
    "@tiptap/extension-placeholder": "^2.0.0",
    "@tiptap/extension-task-item": "^2.0.0",
    "@tiptap/extension-task-list": "^2.0.0",
    "@tiptap/starter-kit": "^2.0.0",
    "lowlight": "^3.0.0",
    "tiptap-markdown": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.you.vibekanban",
    "productName": "Vibe Kanban",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
